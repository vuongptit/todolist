<?xml version="1.0" encoding="utf-8"?>
<!-- activity_add_task.xml - High Contrast Light Mode (Efficient Velocity) -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/on_surface"
            app:title="Thêm Task"
            app:titleTextColor="@color/on_surface" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline_variant" />

        <!-- Form Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTitle"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/task_title"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/on_surface_variant"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDescription"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/task_description"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/on_surface_variant"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/task_category"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCategory"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Chọn danh mục"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/on_surface_variant"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">
                <AutoCompleteTextView
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Priority Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/task_priority"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHigh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Cao"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipCornerRadius="28dp"
                    app:chipBackgroundColor="#1AF44336"
                    android:textColor="#BA1A1A"
                    android:textStyle="bold" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟠 Trung bình"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipCornerRadius="28dp"
                    android:checked="true"
                    app:chipBackgroundColor="#1AFF9800"
                    android:textColor="#D97706"
                    android:textStyle="bold" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Thấp"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipCornerRadius="28dp"
                    app:chipBackgroundColor="#1A4CAF50"
                    android:textColor="#006D2C"
                    android:textStyle="bold" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Deadline Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/task_deadline"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectDeadline"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="📅 Chọn ngày và giờ"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:textStyle="bold"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:drawableStart="@drawable/ic_calendar"
                app:iconTint="@color/primary" />

            <TextView
                android:id="@+id/tvDeadlineValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chưa chọn hạn chót"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Reminder Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/task_reminder"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectReminder"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="🔔 Chọn thời gian nhắc nhở"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:textStyle="bold"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/tvReminderValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chưa chọn thời gian nhắc nhở"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Image Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/task_image"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Image Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTaskImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/ivTaskImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_image"
                    android:visibility="gone"
                    android:contentDescription="Task image preview" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Image Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="📷 Camera"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    app:strokeColor="@color/outline"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallery"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🖼️ Thư viện"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    app:strokeColor="@color/outline"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Upload Progress -->
            <ProgressBar
                android:id="@+id/progressUpload"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/primary"
                android:progressTint="@color/primary"
                android:visibility="gone" />

            <!-- Save Button - Pill shape -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:text="@string/save_task"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="28dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
