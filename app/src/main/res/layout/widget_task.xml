<?xml version="1.0" encoding="utf-8"?>
<!-- Modern Sleek App Widget Layout -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tv_widget_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ GẦN HẠN NHẤT"
            android:textColor="#60A5FA"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Refresh Button -->
        <TextView
            android:id="@+id/btn_refresh_widget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Refresh"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp" />
    </LinearLayout>

    <!-- Divider Line -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp"
        android:src="@android:color/white"
        android:alpha="0.12" />

    <!-- Empty State Text -->
    <TextView
        android:id="@+id/tv_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="8dp"
        android:text="• Đang tải dữ liệu công việc..."
        android:textColor="#94A3B8"
        android:textSize="12sp" />

    <!-- Task Row 1 -->
    <LinearLayout
        android:id="@+id/row_task1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="3dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_check1"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:gravity="center"
            android:text="⚪"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_task1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F8FAFC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_deadline1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Task Row 2 -->
    <LinearLayout
        android:id="@+id/row_task2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="3dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_check2"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:gravity="center"
            android:text="⚪"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_task2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F8FAFC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_deadline2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Task Row 3 -->
    <LinearLayout
        android:id="@+id/row_task3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="3dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_check3"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:gravity="center"
            android:text="⚪"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_task3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F8FAFC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_deadline3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
