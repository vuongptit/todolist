<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme - Light Mode (Efficient Velocity) -->
    <style name="Base.Theme.SmartTodo" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">@color/error</item>
    </style>

    <style name="Theme.SmartTodo" parent="Base.Theme.SmartTodo" />

    <!-- Splash Screen Theme -->
    <style name="Theme.SmartTodo.Splash" parent="Theme.SmartTodo">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- Primary Button - Pill shape, Deep Blue -->
    <style name="Widget.SmartTodo.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.SmartTodo.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/outline_variant</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.SmartTodo.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/surface_container_low</item>
    </style>

    <!-- Card style -->
    <style name="Widget.SmartTodo.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.SmartTodo.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/on_surface</item>
    </style>

    <!-- FAB style -->
    <style name="Widget.SmartTodo.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
    </style>

    <!-- Dialog style -->
    <style name="Widget.SmartTodo.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:background">@color/surface_container_lowest</item>
    </style>

    <!-- Shape Appearance -->
    <style name="ShapeAppearance.App.CircleImageView" parent="">
        <item name="cornerSize">50%</item>
    </style>

</resources>