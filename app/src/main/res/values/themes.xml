<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.SmartTodo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <!-- Secondary Brand Color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_dark</item>
        <!-- Font -->
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <style name="Theme.SmartTodo" parent="Base.Theme.SmartTodo" />

    <!-- Splash Screen Theme -->
    <style name="Theme.SmartTodo.Splash" parent="Theme.SmartTodo">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.SmartTodo.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.SmartTodo.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="Widget.SmartTodo.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary_light</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.SmartTodo.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.SmartTodo.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background_dark</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <!-- FAB style -->
    <style name="Widget.SmartTodo.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
    </style>

    <!-- Dialog style -->
    <style name="Widget.SmartTodo.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:background">@color/surface_dark</item>
        <item name="android:windowBackground">@color/surface_dark</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.SmartTodo.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_variant_dark</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Circle ImageView Shape -->
    <style name="ShapeAppearance.App.CircleImageView" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>